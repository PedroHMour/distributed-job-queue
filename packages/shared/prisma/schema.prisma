generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobType {
  EMAIL_DELIVERY
  IMAGE_PROCESSING
  REPORT_GENERATION
}

enum JobStatus {
  PENDING
  ACTIVE
  COMPLETED
  FAILED
  RETRYING
  DEAD
}

model JobExecution {
  id              String    @id @default(uuid())
  
  // CORREÇÃO: Tornado opcional (?) pois o job nasce antes de ir para o Redis
  bullmqJobId     String?   @unique @map("bullmq_job_id")
  
  jobType         JobType   @map("job_type")
  status          JobStatus @default(PENDING)
  priority        Int       @default(0)
  
  inputPayload    Json      @map("input_payload")
  outputPayload   Json?     @map("output_payload")
  
  attemptNumber   Int       @default(0) @map("attempt_number")
  maxAttempts     Int       @default(3) @map("max_attempts")
  
  errorMessage    String?   @map("error_message")
  errorStack      String?   @map("error_stack")
  
  enqueuedAt      DateTime  @default(now()) @map("enqueued_at")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  processingMs    Int?      @map("processing_ms")
  
  workerInstanceId String?  @map("worker_instance_id")

  deadLetterEntry DeadLetterEntry?

  @@index([status])
  @@index([jobType])
  @@index([enqueuedAt])
  @@index([status, jobType])
  
  @@map("job_executions")
}

model DeadLetterEntry {
  id              String    @id @default(uuid())
  jobExecutionId  String    @unique @map("job_execution_id")
  bullmqJobId     String    @unique @map("bullmq_job_id")
  jobType         JobType   @map("job_type")
  inputPayload    Json      @map("input_payload")
  
  failureHistory  Json      @map("failure_history")
  
  resolvedAt      DateTime? @map("resolved_at")
  resolvedBy      String?   @map("resolved_by")
  resolutionNote  String?   @map("resolution_note")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  
  jobExecution    JobExecution @relation(fields: [jobExecutionId], references: [id])
  
  @@index([resolvedAt])
  @@index([jobType])
  
  @@map("dead_letter_entries")
}