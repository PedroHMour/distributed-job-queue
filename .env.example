# PostgreSQL
POSTGRES_USER=jobqueue
POSTGRES_PASSWORD=jobqueue_secret
POSTGRES_DB=jobqueue_db
DATABASE_URL="postgresql://jobqueue:jobqueue_secret@localhost:5432/jobqueue_db?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API
API_PORT=3000
NODE_ENV=development

# Workers — concorrência por tipo de job
WORKER_CONCURRENCY=5
CONCURRENCY_EMAIL=10
CONCURRENCY_IMAGE=2
CONCURRENCY_REPORT=5

# API Key (deixe vazio para desativar em desenvolvimento)
API_KEY=

# Rate limiting
RATE_LIMIT_MAX=100